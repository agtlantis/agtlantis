{
  "name": "@agtlantis/core",
  "version": "0.5.1",
  "description": "A framework for building Agents and Pipelines consistently on top of AI SDK",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsgo -p tsconfig.build.json",
    "test": "vitest run src/",
    "test:unit": "vitest run src/",
    "test:e2e": "REAL_AI_ENABLED=true vitest run e2e/",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "yaml": "^2.8.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@google/genai": "^1.0.0",
    "ai": "^6.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.10",
    "@ai-sdk/openai": "^3.0.12",
    "@google/genai": "^1.37.0",
    "ai": "^6.0.39",
    "dotenv": "^17.2.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "zod": "^4.3.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "framework"
  ],
  "license": "MIT"
}
